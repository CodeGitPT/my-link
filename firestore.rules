rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유저 프로필 문서
    match /users/{userId} {
      // 읽기: 누구나 가능 (displayName 중복 검사 및 프로필 조회용)
      allow read: if true;
      
      // 쓰기 (생성, 수정, 삭제): 로그인한 본인만 가능
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // 개별 유저의 링크 서브컬렉션
      match /links/{linkId} {
        // 읽기: 누구나 가능
        allow read: if true;
        
        // 쓰기: 로그인한 본인만 가능
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
